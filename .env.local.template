# Patricia Chatbot - Environment Variables Configuration
# Copy this file to .env.local and fill in your credentials

# ============================================
# LLM Configuration
# ============================================

# Enable/disable LLM-powered responses
# Set to "true" to use Amazon Bedrock Claude
# Set to "false" to use TF-IDF template fallback
USE_LLM=true

# ============================================
# AWS Bedrock Credentials
# ============================================

# Your AWS region (e.g., us-east-1, us-west-2, eu-west-1)
AWS_REGION=us-east-1

# AWS Access Key ID
# Get from AWS IAM Console: https://console.aws.amazon.com/iam/
AWS_ACCESS_KEY_ID=your-access-key-id-here

# AWS Secret Access Key
# Keep this secret! Never commit to git
AWS_SECRET_ACCESS_KEY=your-secret-access-key-here

# ============================================
# Optional: Advanced Configuration
# ============================================

# Override the default Claude model
# Default: anthropic.claude-3-5-sonnet-20241022-v2:0
# Other options:
#   - anthropic.claude-3-5-sonnet-20240620-v1:0 (previous version)
#   - anthropic.claude-3-haiku-20240307-v1:0 (faster, cheaper)
#   - anthropic.claude-3-opus-20240229-v1:0 (most capable, expensive)
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# ============================================
# Setup Instructions
# ============================================
#
# 1. Copy this file:
#    cp .env.local.template .env.local
#
# 2. Get AWS credentials:
#    - Go to AWS Console → IAM → Users
#    - Create or select a user
#    - Security credentials → Create access key
#    - Choose "Application running outside AWS"
#    - Copy Access Key ID and Secret Access Key
#
# 3. Enable Bedrock access:
#    - Go to AWS Console → Bedrock
#    - Request model access for Claude models
#    - Wait for approval (usually instant for Claude 3.5 Sonnet)
#
# 4. Test locally:
#    npm run dev
#    Open http://localhost:3000
#
# 5. Deploy to Vercel:
#    - Vercel Dashboard → Your Project → Settings → Environment Variables
#    - Add each variable above (except comments)
#    - Redeploy
#
# ============================================
# Security Notes
# ============================================
#
# - NEVER commit .env.local to git (already in .gitignore)
# - Rotate credentials regularly
# - Use IAM roles with minimum permissions
# - Required IAM permissions:
#   {
#     "Version": "2012-10-17",
#     "Statement": [
#       {
#         "Effect": "Allow",
#         "Action": [
#           "bedrock:InvokeModel"
#         ],
#         "Resource": "arn:aws:bedrock:*::foundation-model/anthropic.claude-*"
#       }
#     ]
#   }
